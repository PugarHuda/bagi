{
  "name": "extension",
  "displayName": "Bagi — Split-tip USDC on Avalanche",
  "version": "0.4.0",
  "description": "Trustless USDC tip-splitter on Avalanche C-Chain. One-click tip creators on Twitter/X, YouTube, GitHub, and LinkedIn.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.11.0",
    "lucide-react": "^0.453.0",
    "plasmo": "^0.88.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.0"
  },
  "manifest": {
    "host_permissions": [
      "https://twitter.com/*",
      "https://x.com/*",
      "https://www.youtube.com/*",
      "https://github.com/*",
      "https://www.linkedin.com/in/*",
      "https://api.avax-test.network/*"
    ],
    "permissions": [
      "storage",
      "activeTab"
    ]
  }
}
